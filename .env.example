# Backblaze B2 (required) — keys match the parent CLAUDE.md standard.
B2_ENDPOINT=your_b2_endpoint
B2_REGION=your_b2_region
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example values (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-video-insights-bucket

# Frontend -> API URL (used by apps/web). Leave blank to default to http://localhost:8000.
NEXT_PUBLIC_API_URL=

# NVIDIA NIM (optional). Without this key the pipeline still downloads + uploads
# the source video to B2 and finishes with status "done_no_analysis".
NVIDIA_API_KEY=
NVIDIA_ASR_MODEL=nvidia/parakeet-tdt-0.6b-v2
NVIDIA_INSIGHTS_MODEL=meta/llama-3.3-70b-instruct

# Pipeline knobs
WORK_DIR=./.work
MAX_VIDEO_SECONDS=5400
MAX_CONCURRENT_JOBS=1
# Comma-separated allowlist of accepted video host suffixes.
ALLOWED_VIDEO_HOSTS=youtube.com,youtu.be,m.youtube.com,www.youtube.com

# --- Optional API tuning (defaults are sensible; only override if you need to) ---
# Override the NVIDIA NIM API base URL (e.g. for self-hosted NIMs)
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Port the FastAPI app listens on
# API_PORT=8000

# Comma-separated allowlist for CORS Origin (default covers local dev)
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional regex fallback for CORS Origin (used when an exact origin
# doesn't match API_CORS_ORIGINS)
# API_CORS_ORIGIN_REGEX=
